.profile{min-height:100vh;padding-bottom:80rpx}.profile__header{align-items:flex-end;display:flex;justify-content:space-between;padding:96rpx 32rpx 48rpx;position:relative}.profile__header::before{color:rgba(139,115,85,.82);content:"COFFEE ATLAS";font-size:20rpx;font-weight:600;left:32rpx;letter-spacing:.34em;position:absolute;text-transform:uppercase;top:48rpx}.profile__title{color:var(--color-coffee-dark,#3e2a1e);font-size:56rpx;font-weight:700;letter-spacing:.04em}.profile__logout{padding:16rpx 0 16rpx 32rpx}.profile__logout-text{color:rgba(139,115,85,.9);font-size:26rpx;font-weight:600}.profile__login-banner{align-items:center;background:linear-gradient(180deg,hsla(37,39%,94%,.98),hsla(0,0%,100%,.96));border:2rpx solid rgba(107,83,68,.08);border-radius:48rpx;box-shadow:var(--shadow-card,0 24rpx 60rpx rgba(62,42,30,.06));display:flex;flex-direction:column;gap:28rpx;margin:0 32rpx 40rpx;padding:48rpx 40rpx}.profile__login-hint{color:rgba(107,83,68,.88);font-size:28rpx;line-height:1.6;text-align:center}.profile__login-btn{background:var(--color-coffee-dark,#3e2a1e)!important;border-radius:var(--radius-pill,1998rpx)!important;box-shadow:0 28rpx 56rpx rgba(62,42,30,.16);color:#fff!important;font-size:32rpx!important;font-weight:600!important;height:96rpx!important;line-height:96rpx!important;max-width:520rpx;padding:0 48rpx!important;width:100%}.profile__user{padding:0 32rpx 32rpx}.profile__user-name{color:rgba(107,83,68,.88);font-size:30rpx;font-weight:500}.profile__stats{align-items:center;background:hsla(0,0%,100%,.96);border:2rpx solid rgba(107,83,68,.08);border-radius:48rpx;box-shadow:var(--shadow-card,0 24rpx 60rpx rgba(62,42,30,.06));display:flex;margin:0 32rpx 48rpx;padding:36rpx 0}.profile__stat{align-items:center;display:flex;flex:1;flex-direction:column;gap:12rpx}.profile__stat-num{color:var(--color-coffee-dark,#3e2a1e);font-size:56rpx;font-weight:700}.profile__stat-label{color:rgba(139,115,85,.84);font-size:24rpx;font-weight:600;letter-spacing:.16em;text-transform:uppercase}.profile__stat-divider{background:rgba(139,115,85,.12);height:84rpx;width:2rpx}.profile__tabs{border-bottom:2rpx solid rgba(139,115,85,.12);display:flex;margin:0 32rpx 40rpx}.profile__tab{padding:0 40rpx 28rpx;position:relative}.profile__tab--active::after{background:var(--color-coffee-dark,#3e2a1e);border-radius:var(--radius-pill,1998rpx);bottom:0;content:"";height:4rpx;left:0;position:absolute;right:0}.profile__tab-text{color:rgba(139,115,85,.72);font-size:28rpx;font-weight:600;letter-spacing:.12em}.profile__tab--active .profile__tab-text{color:var(--color-coffee-dark,#3e2a1e)}.profile__list{display:flex;flex-direction:column;gap:24rpx;padding:0 32rpx}.profile__empty{align-items:center;display:flex;flex-direction:column;gap:24rpx;padding:128rpx 0}.profile__empty-text{color:rgba(139,115,85,.8);font-size:30rpx}.profile-bean-row{align-items:center;background:hsla(0,0%,100%,.96);border:2rpx solid rgba(107,83,68,.08);border-radius:48rpx;box-shadow:var(--shadow-card,0 24rpx 60rpx rgba(62,42,30,.06));display:flex;gap:28rpx;padding:32rpx}.profile-bean-row__image{background:linear-gradient(180deg,hsla(37,39%,94%,.98),hsla(34,34%,87%,.92));border-radius:36rpx;flex-shrink:0;height:128rpx;overflow:hidden;width:128rpx}.profile-bean-row__img{height:100%;width:100%}.profile-bean-row__placeholder{align-items:center;display:flex;height:100%;justify-content:center;width:100%}.profile-bean-row__info{flex:1;min-width:0}.profile-bean-row__name{color:var(--color-coffee-dark,#3e2a1e);display:block;font-size:32rpx;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.profile-bean-row__meta{color:rgba(139,115,85,.86);display:block;font-size:26rpx;line-height:1.4;margin-top:12rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.profile-bean-row__right{align-items:flex-end;display:flex;flex-direction:column;flex-shrink:0;gap:16rpx}.profile-bean-row__price{color:var(--color-coffee-dark,#3e2a1e);font-size:30rpx;font-weight:600}.profile-bean-row__unfav{padding:12rpx}.profile-fav-row{align-items:center;background:hsla(0,0%,100%,.96);border:2rpx solid rgba(107,83,68,.08);border-radius:40rpx;box-shadow:var(--shadow-card,0 24rpx 60rpx rgba(62,42,30,.06));display:flex;gap:24rpx;justify-content:space-between;padding:32rpx}.profile-fav-row__id{color:rgba(107,83,68,.82);flex:1;font-size:26rpx;line-height:1.5;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.profile-fav-row__unfav{flex-shrink:0;padding:12rpx}
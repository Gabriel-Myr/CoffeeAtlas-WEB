.profile {
  min-height: 100vh;
  background: radial-gradient(circle at top, rgba(245, 240, 232, 0.96), rgba(253, 250, 244, 0.98) 38%), linear-gradient(180deg, #f7f1e8 0%, #fdfaf4 42%, #fffdf8 100%);
  padding: 56rpx 0 80rpx;
}
.profile__hero {
  margin: 0 32rpx;
  padding: 34rpx 30rpx 28rpx;
  border-radius: 34rpx;
  border: 1rpx solid rgba(107, 83, 68, 0.08);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(253, 250, 244, 0.94)), #fff;
  box-shadow: 0 24rpx 48rpx rgba(62, 42, 30, 0.05), inset 0 1rpx 0 rgba(255, 255, 255, 0.86);
}
.profile__hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}
.profile__identity {
  flex: 1;
  min-width: 0;
}
.profile__eyebrow {
  display: block;
  font-size: 20rpx;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: rgba(139, 115, 85, 0.72);
}
.profile__name {
  display: block;
  margin-top: 12rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-coffee-dark, #3E2A1E);
  line-height: 1.2;
}
.profile__status {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(107, 83, 68, 0.84);
}
.profile__seal {
  width: 108rpx;
  height: 108rpx;
  border-radius: 30rpx;
  background: radial-gradient(circle at top, rgba(245, 240, 232, 0.98), rgba(255, 255, 255, 0.92) 72%), #fff;
  border: 1rpx solid rgba(107, 83, 68, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.profile__seal-text {
  font-size: 42rpx;
  font-weight: 700;
  color: var(--color-coffee-dark, #3E2A1E);
  letter-spacing: 0.06em;
}
.profile__hero-actions {
  margin-top: 26rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}
.profile__summary-pill {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(245, 240, 232, 0.96);
  border: 1rpx solid rgba(107, 83, 68, 0.08);
}
.profile__summary-pill-text {
  font-size: 22rpx;
  color: var(--color-coffee-light, #8B7355);
}
.profile__login-btn {
  margin: 0;
  min-width: 220rpx;
  height: 76rpx !important;
  line-height: 76rpx !important;
  padding: 0 36rpx !important;
  border-radius: 999rpx !important;
  background: var(--color-coffee-dark, #3E2A1E) !important;
  color: #fff !important;
  font-size: 26rpx !important;
  border: none !important;
}
.profile__login-btn::after {
  border: none;
}
.profile__logout {
  font-size: 24rpx;
  color: var(--color-accent-rust, #c85c3d);
}
.profile__stats {
  margin-top: 28rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}
.profile__debug-card {
  margin: 24rpx 32rpx 0;
  padding: 24rpx 26rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(107, 83, 68, 0.08);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(253, 250, 244, 0.94)), #fff;
  box-shadow: 0 16rpx 32rpx rgba(62, 42, 30, 0.04), inset 0 1rpx 0 rgba(255, 255, 255, 0.84);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}
.profile__debug-copy {
  flex: 1;
  min-width: 0;
}
.profile__debug-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-coffee-dark, #3E2A1E);
}
.profile__debug-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: rgba(139, 115, 85, 0.82);
  word-break: break-all;
}
.profile__debug-pill {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
}
.profile__debug-pill--cloud {
  background: rgba(90, 90, 64, 0.12);
  color: var(--color-accent-olive, #5A5A40);
}
.profile__debug-pill--local {
  background: rgba(232, 154, 127, 0.12);
  color: var(--color-accent-rust, #c85c3d);
}
.profile__debug-pill--unset {
  background: rgba(139, 115, 85, 0.12);
  color: var(--color-coffee-light, #8B7355);
}
.profile__debug-pill-text {
  font-size: 20rpx;
  font-weight: 600;
}
.profile__stat {
  padding: 20rpx 12rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(107, 83, 68, 0.06);
  text-align: center;
}
.profile__stat-num {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-coffee-dark, #3E2A1E);
}
.profile__stat-label {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  color: rgba(139, 115, 85, 0.78);
}
.profile__tabs {
  margin: 26rpx 32rpx 18rpx;
  padding: 8rpx;
  display: flex;
  gap: 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 1rpx solid rgba(107, 83, 68, 0.08);
}
.profile__tab {
  flex: 1;
  min-width: 0;
  padding: 18rpx 12rpx;
  border-radius: 999rpx;
  text-align: center;
}
.profile__tab--active {
  background: var(--color-coffee-dark, #3E2A1E);
  box-shadow: 0 12rpx 22rpx rgba(62, 42, 30, 0.12);
}
.profile__tab-text {
  font-size: 24rpx;
  color: rgba(139, 115, 85, 0.78);
  white-space: nowrap;
}
.profile__tab--active .profile__tab-text {
  color: #fff;
}
.profile__list {
  padding: 0 32rpx 24rpx;
}
.profile__fav-action {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(245, 240, 232, 0.96);
  border: 1rpx solid rgba(107, 83, 68, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
}
.profile__empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 88rpx 24rpx;
  gap: 18rpx;
}
.profile__empty-text {
  font-size: 26rpx;
  line-height: 1.6;
  text-align: center;
  color: rgba(139, 115, 85, 0.82);
}
.profile-bean-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(107, 83, 68, 0.08);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(253, 250, 244, 0.94)), #fff;
  box-shadow: 0 18rpx 36rpx rgba(62, 42, 30, 0.04), inset 0 1rpx 0 rgba(255, 255, 255, 0.84);
}
.profile-bean-row__image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  overflow: hidden;
  flex-shrink: 0;
  background: #f0ebe3;
}
.profile-bean-row__img {
  width: 100%;
  height: 100%;
}
.profile-bean-row__placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.profile-bean-row__info {
  flex: 1;
  min-width: 0;
}
.profile-bean-row__name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-coffee-dark, #3E2A1E);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.profile-bean-row__meta {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: rgba(139, 115, 85, 0.82);
  line-height: 1.5;
}
.profile-bean-row__side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: center;
  gap: 12rpx;
  flex-shrink: 0;
}
.profile-bean-row__price {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-coffee-dark, #3E2A1E);
}
.profile-bean-row__action {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: rgba(245, 240, 232, 0.96);
  border: 1rpx solid rgba(107, 83, 68, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
}
.profile-bean-row__note {
  font-size: 20rpx;
  color: rgba(139, 115, 85, 0.78);
}

.profile{background:radial-gradient(circle at top,hsla(37,39%,94%,.96),hsla(40,69%,97%,.98) 38%),linear-gradient(180deg,#f7f1e8,#fdfaf4 42%,#fffdf8);min-height:100vh;padding:56rpx 0 80rpx}.profile__hero{background:linear-gradient(180deg,hsla(0,0%,100%,.98),hsla(40,69%,97%,.94)),#fff;border:1rpx solid rgba(107,83,68,.08);border-radius:34rpx;box-shadow:0 24rpx 48rpx rgba(62,42,30,.05),inset 0 1rpx 0 hsla(0,0%,100%,.86);margin:0 32rpx;padding:34rpx 30rpx 28rpx}.profile__hero-top{align-items:center;display:flex;gap:24rpx;justify-content:space-between}.profile__identity{flex:1;min-width:0}.profile__eyebrow{color:rgba(139,115,85,.72);display:block;font-size:20rpx;letter-spacing:.28em;text-transform:uppercase}.profile__name{color:var(--color-coffee-dark,#3e2a1e);display:block;font-size:40rpx;font-weight:700;line-height:1.2;margin-top:12rpx}.profile__status{color:rgba(107,83,68,.84);display:block;font-size:24rpx;line-height:1.6;margin-top:12rpx}.profile__seal{align-items:center;background:radial-gradient(circle at top,hsla(37,39%,94%,.98),hsla(0,0%,100%,.92) 72%),#fff;border:1rpx solid rgba(107,83,68,.08);border-radius:30rpx;display:flex;flex-shrink:0;height:108rpx;justify-content:center;width:108rpx}.profile__seal-text{color:var(--color-coffee-dark,#3e2a1e);font-size:42rpx;font-weight:700;letter-spacing:.06em}.profile__hero-actions{align-items:center;display:flex;gap:20rpx;justify-content:space-between;margin-top:26rpx}.profile__summary-pill{align-items:center;background:hsla(37,39%,94%,.96);border:1rpx solid rgba(107,83,68,.08);border-radius:999rpx;display:inline-flex;padding:12rpx 18rpx}.profile__summary-pill-text{color:var(--color-coffee-light,#8b7355);font-size:22rpx}.profile__login-btn{background:var(--color-coffee-dark,#3e2a1e)!important;border:none!important;border-radius:999rpx!important;color:#fff!important;font-size:26rpx!important;height:76rpx!important;line-height:76rpx!important;margin:0;min-width:220rpx;padding:0 36rpx!important}.profile__login-btn::after{border:none}.profile__logout{color:var(--color-accent-rust,#c85c3d);font-size:24rpx}.profile__stats{display:grid;gap:14rpx;grid-template-columns:repeat(3,1fr);margin-top:28rpx}.profile__debug-card{align-items:center;background:linear-gradient(180deg,hsla(0,0%,100%,.98),hsla(40,69%,97%,.94)),#fff;border:1rpx solid rgba(107,83,68,.08);border-radius:28rpx;box-shadow:0 16rpx 32rpx rgba(62,42,30,.04),inset 0 1rpx 0 hsla(0,0%,100%,.84);display:flex;gap:20rpx;justify-content:space-between;margin:24rpx 32rpx 0;padding:24rpx 26rpx}.profile__debug-copy{flex:1;min-width:0}.profile__debug-title{color:var(--color-coffee-dark,#3e2a1e);display:block;font-size:28rpx;font-weight:600}.profile__debug-desc{color:rgba(139,115,85,.82);display:block;font-size:22rpx;line-height:1.6;margin-top:10rpx;word-break:break-all}.profile__debug-pill{border-radius:999rpx;padding:10rpx 18rpx}.profile__debug-pill--cloud{background:rgba(90,90,64,.12);color:var(--color-accent-olive,#5a5a40)}.profile__debug-pill--local{background:hsla(15,70%,70%,.12);color:var(--color-accent-rust,#c85c3d)}.profile__debug-pill--unset{background:rgba(139,115,85,.12);color:var(--color-coffee-light,#8b7355)}.profile__debug-pill-text{font-size:20rpx;font-weight:600}.profile__stat{background:hsla(0,0%,100%,.82);border:1rpx solid rgba(107,83,68,.06);border-radius:24rpx;padding:20rpx 12rpx;text-align:center}.profile__stat-num{color:var(--color-coffee-dark,#3e2a1e);display:block;font-size:34rpx;font-weight:700}.profile__stat-label{color:rgba(139,115,85,.78);display:block;font-size:20rpx;margin-top:8rpx}.profile__tabs{background:hsla(0,0%,100%,.86);border:1rpx solid rgba(107,83,68,.08);border-radius:999rpx;display:flex;gap:8rpx;margin:26rpx 32rpx 18rpx;padding:8rpx}.profile__tab{border-radius:999rpx;flex:1;min-width:0;padding:18rpx 12rpx;text-align:center}.profile__tab--active{background:var(--color-coffee-dark,#3e2a1e);box-shadow:0 12rpx 22rpx rgba(62,42,30,.12)}.profile__tab-text{color:rgba(139,115,85,.78);font-size:24rpx;white-space:nowrap}.profile__tab--active .profile__tab-text{color:#fff}.profile__list{padding:0 32rpx 24rpx}.profile__roaster-list{display:flex;flex-direction:column;gap:16rpx}.profile__fav-action{align-items:center;background:hsla(37,39%,94%,.96);border:1rpx solid rgba(107,83,68,.08);border-radius:50%;display:flex;height:64rpx;justify-content:center;width:64rpx}.profile__empty{align-items:center;display:flex;flex-direction:column;gap:18rpx;padding:88rpx 24rpx}.profile__empty-text{color:rgba(139,115,85,.82);font-size:26rpx;line-height:1.6;text-align:center}.profile-bean-row{align-items:center;background:linear-gradient(180deg,hsla(0,0%,100%,.98),hsla(40,69%,97%,.94)),#fff;border:1rpx solid rgba(107,83,68,.08);border-radius:28rpx;box-shadow:0 18rpx 36rpx rgba(62,42,30,.04),inset 0 1rpx 0 hsla(0,0%,100%,.84);display:flex;gap:20rpx;margin-bottom:16rpx;padding:24rpx}.profile-bean-row__image{background:#f0ebe3;border-radius:24rpx;flex-shrink:0;height:120rpx;overflow:hidden;width:120rpx}.profile-bean-row__img{height:100%;width:100%}.profile-bean-row__placeholder{align-items:center;display:flex;height:100%;justify-content:center;width:100%}.profile-bean-row__info{flex:1;min-width:0}.profile-bean-row__name{color:var(--color-coffee-dark,#3e2a1e);display:block;font-size:30rpx;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.profile-bean-row__meta{color:rgba(139,115,85,.82);display:block;font-size:22rpx;line-height:1.5;margin-top:10rpx}.profile-bean-row__side{align-items:flex-end;display:flex;flex-direction:column;flex-shrink:0;gap:12rpx;justify-content:center}.profile-bean-row__price{color:var(--color-coffee-dark,#3e2a1e);font-size:28rpx;font-weight:700}.profile-bean-row__action{align-items:center;background:hsla(37,39%,94%,.96);border:1rpx solid rgba(107,83,68,.08);border-radius:50%;display:flex;height:58rpx;justify-content:center;width:58rpx}.profile-bean-row__note{color:rgba(139,115,85,.78);font-size:20rpx}
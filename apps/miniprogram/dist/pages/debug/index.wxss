.debug-page{min-height:100vh;padding:28rpx 32rpx 48rpx}.debug-page__hero{padding:24rpx 8rpx 32rpx}.debug-page__eyebrow{color:rgba(139,115,85,.72);display:block;font-size:20rpx;letter-spacing:.28em;text-transform:uppercase}.debug-page__title{color:var(--color-coffee-dark,#3e2a1e);display:block;font-size:44rpx;font-weight:700;line-height:1.2;margin-top:14rpx}.debug-page__subtitle{color:rgba(107,83,68,.82);display:block;font-size:24rpx;line-height:1.7;margin-top:16rpx}.debug-page__card{background:linear-gradient(180deg,hsla(0,0%,100%,.98),hsla(40,69%,97%,.94)),#fff;border:1rpx solid rgba(107,83,68,.08);border-radius:30rpx;box-shadow:0 18rpx 36rpx rgba(62,42,30,.05),inset 0 1rpx 0 hsla(0,0%,100%,.86);margin-top:20rpx;padding:28rpx}.debug-page__card-head{align-items:center;display:flex;gap:18rpx;justify-content:space-between}.debug-page__card-title{color:var(--color-coffee-dark,#3e2a1e);display:block;font-size:28rpx;font-weight:600}.debug-page__value{color:var(--color-coffee-dark,#3e2a1e);display:block;font-size:26rpx;line-height:1.7;margin-top:16rpx;word-break:break-all}.debug-page__meta{color:rgba(139,115,85,.78);display:block;font-size:22rpx;line-height:1.7;margin-top:12rpx}.debug-page__warning{background:hsla(15,70%,70%,.12);border-radius:20rpx;color:var(--color-accent-rust,#c85c3d);display:block;font-size:22rpx;line-height:1.7;margin-top:12rpx;padding:14rpx 18rpx}.debug-page__badge{border-radius:999rpx;font-size:20rpx;font-weight:600;padding:8rpx 18rpx}.debug-page__badge--cloud{background:rgba(90,90,64,.12);color:var(--color-accent-olive,#5a5a40)}.debug-page__badge--local{background:hsla(15,70%,70%,.12);color:var(--color-accent-rust,#c85c3d)}.debug-page__badge--unset{background:rgba(139,115,85,.12);color:var(--color-coffee-light,#8b7355)}.debug-page__input{background:hsla(37,39%,94%,.96);border:1rpx solid rgba(107,83,68,.08);border-radius:22rpx;color:var(--color-coffee-dark,#3e2a1e);font-size:24rpx;margin-top:20rpx;padding:20rpx 24rpx;width:100%}.debug-page__actions,.debug-page__probe-grid{display:grid;gap:16rpx}.debug-page__actions{grid-template-columns:repeat(2,minmax(0,1fr));margin-top:20rpx}.debug-page__probe-grid{grid-template-columns:repeat(2,minmax(0,1fr));margin-top:20rpx}.debug-page__button,.debug-page__probe-button{background:hsla(37,39%,94%,.92)!important;border:1rpx solid rgba(107,83,68,.08)!important;border-radius:999rpx!important;color:var(--color-coffee-dark,#3e2a1e)!important;font-size:24rpx!important;height:80rpx!important;line-height:80rpx!important;margin:0}.debug-page__button::after,.debug-page__probe-button::after{border:none}.debug-page__button--primary{background:var(--color-coffee-dark,#3e2a1e)!important;color:#fff!important}.debug-page__result{background:hsla(37,39%,94%,.72);border:1rpx solid rgba(107,83,68,.08);border-radius:22rpx;margin-top:18rpx;padding:20rpx}.debug-page__result-title{color:var(--color-coffee-dark,#3e2a1e);display:block;font-size:22rpx;font-weight:600}.debug-page__result-code,.debug-page__result-error{display:block;font-size:22rpx;line-height:1.7;margin-top:14rpx;white-space:pre-wrap;word-break:break-all}.debug-page__result-code{color:rgba(62,42,30,.88)}.debug-page__result-error{color:var(--color-accent-rust,#c85c3d)}
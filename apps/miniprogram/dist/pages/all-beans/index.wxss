.all-beans{min-height:100vh;padding:64rpx 0 80rpx}.all-beans__hero{align-items:center;display:flex;flex-direction:column;padding:96rpx 64rpx 56rpx;text-align:center}.all-beans__title-en{color:var(--color-coffee-dark,#3e2a1e);font-size:56rpx;font-weight:700;letter-spacing:.05em;line-height:1}.all-beans__title-atlas{color:var(--color-coffee-light,#8b7355);font-family:var(--font-serif,Georgia,serif);font-size:64rpx;font-style:italic;font-weight:500;line-height:1;margin-top:-8rpx}.all-beans__subtitle{color:rgba(139,115,85,.84);font-size:20rpx;font-weight:600;letter-spacing:.32em;margin-top:28rpx;text-transform:uppercase}.all-beans__count{color:rgba(139,115,85,.92);font-size:28rpx;font-weight:500;margin-top:24rpx}.all-beans__query-bar{align-items:center;display:flex;gap:24rpx;justify-content:space-between;margin:-16rpx 32rpx 32rpx;padding:0 12rpx}.all-beans__query-text{color:rgba(139,115,85,.88);font-size:26rpx}.all-beans__query-clear{color:var(--color-accent-rust,#c85c3d);font-size:26rpx;font-weight:600}.all-beans__list{padding:0 32rpx}.all-beans__end,.all-beans__loading{padding:56rpx 0 16rpx;text-align:center}.all-beans__end-text,.all-beans__loading-text{color:rgba(139,115,85,.72);font-size:26rpx}
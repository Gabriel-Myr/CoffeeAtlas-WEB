.index-page {
  min-height: 100vh;
  padding-bottom: 80rpx;
}
.index-page__header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 96rpx 48rpx 56rpx;
  text-align: center;
}
.index-page__title-en {
  color: var(--color-coffee-dark, #3e2a1e);
  font-size: 56rpx;
  font-weight: 700;
  letter-spacing: 0.05em;
  line-height: 1;
}
.index-page__title-atlas {
  margin-top: -8rpx;
  color: var(--color-coffee-light, #8b7355);
  font-family: var(--font-serif, Georgia, serif);
  font-size: 64rpx;
  font-style: italic;
  font-weight: 500;
  line-height: 1;
}
.index-page__subtitle {
  margin-top: 28rpx;
  color: rgba(139, 115, 85, 0.84);
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 0.32em;
  text-transform: uppercase;
}
.index-page__tabs {
  display: flex;
  justify-content: center;
  margin: 0 48rpx 56rpx;
  border-bottom: 2rpx solid var(--color-border, rgba(107, 83, 68, 0.12));
}
.index-page__tab {
  position: relative;
  padding: 0 48rpx 28rpx;
}
.index-page__tab--active::after {
  content: "";
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  height: 4rpx;
  background: var(--color-coffee-dark, #3e2a1e);
  border-radius: var(--radius-pill, 1998rpx);
  animation: fade-in 0.2s ease forwards;
}
.index-page__tab-text {
  color: rgba(139, 115, 85, 0.72);
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  transition: color 0.2s var(--smooth-easing, cubic-bezier(0.4, 0, 0.2, 1));
}
.index-page__tab--active .index-page__tab-text {
  color: var(--color-coffee-dark, #3e2a1e);
}
.index-page__content {
  padding: 0 var(--page-gutter);
}
.index-page__list {
  padding-top: 16rpx;
}
.index-page__notice {
  margin-bottom: 36rpx;
  padding: 28rpx 32rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid rgba(107, 83, 68, 0.08);
  border-radius: 40rpx;
  box-shadow: 0 24rpx 48rpx rgba(62, 42, 30, 0.04);
}
.index-page__notice-label {
  display: block;
  margin-bottom: 12rpx;
  color: var(--color-accent-rust, #c85c3d);
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
}
.index-page__notice-text {
  display: block;
  color: rgba(107, 83, 68, 0.88);
  font-size: 26rpx;
  line-height: 1.6;
}
.discover__nav {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 8rpx 36rpx;
  margin-bottom: 36rpx;
  border-bottom: 2rpx solid rgba(107, 83, 68, 0.1);
  animation: slide-in-left 0.3s ease forwards;
}
.discover__nav-back {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  flex-shrink: 0;
  color: var(--color-coffee-dark, #3e2a1e);
  font-size: 32rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 2rpx solid rgba(107, 83, 68, 0.15);
  border-radius: 50%;
  box-shadow: 0 20rpx 48rpx rgba(62, 42, 30, 0.05);
}
.discover__nav-info {
  min-width: 0;
}
.discover__nav-title {
  display: block;
  color: var(--color-coffee-dark, #3e2a1e);
  font-size: 34rpx;
  font-weight: 600;
}
.discover__nav-sub {
  display: block;
  margin-top: 8rpx;
  color: rgba(139, 115, 85, 0.8);
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
}
.discover__continents {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}
.discover__countries {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}
.discover__beans {
  padding-top: 12rpx;
}
.continent-card {
  display: flex;
  align-items: stretch;
  min-height: 176rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.96);
  border: 2rpx solid rgba(107, 83, 68, 0.08);
  border-radius: 48rpx;
  box-shadow: var(--shadow-card, 0 24rpx 60rpx rgba(62, 42, 30, 0.06));
  animation: fade-in-up 0.45s ease forwards;
  opacity: 0;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.continent-card__map {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 176rpx;
  height: 176rpx;
  flex-shrink: 0;
  padding: 28rpx;
  background: linear-gradient(180deg, rgba(245, 240, 232, 0.96), rgba(240, 232, 223, 0.96));
  border-right: 2rpx solid rgba(107, 83, 68, 0.06);
}
.continent-card__svg {
  width: 116rpx;
  height: 116rpx;
}
.continent-card__body {
  display: flex;
  flex: 1;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
  padding: 36rpx 32rpx;
}
.continent-card__name {
  display: block;
  color: var(--color-coffee-dark, #3e2a1e);
  font-size: 36rpx;
  font-weight: 600;
}
.continent-card__meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 12rpx;
}
.continent-card__dot {
  width: 12rpx;
  height: 12rpx;
  flex-shrink: 0;
  border-radius: 50%;
}
.continent-card__count {
  color: rgba(139, 115, 85, 0.86);
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 0.08em;
}
.continent-card__arrow {
  padding-right: 32rpx;
  align-self: center;
  color: var(--color-coffee-pale, #d4c4b5);
  font-size: 48rpx;
  flex-shrink: 0;
}
.continent-card-active {
  transform: scale(0.98);
  box-shadow: var(--shadow-card-hover, 0 36rpx 80rpx rgba(62, 42, 30, 0.1));
}
.country-card {
  overflow: hidden;
  background: rgba(255, 255, 255, 0.96);
  border: 2rpx solid rgba(107, 83, 68, 0.08);
  border-radius: 40rpx;
  box-shadow: var(--shadow-card, 0 24rpx 60rpx rgba(62, 42, 30, 0.06));
  animation: slide-in-bounce-left 0.5s var(--spring-easing, cubic-bezier(0.175, 0.885, 0.32, 1.275)) forwards;
  opacity: 0;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.country-card__map {
  position: relative;
  width: 100%;
  padding-top: 70%;
  background: linear-gradient(180deg, rgba(245, 240, 232, 0.96), rgba(240, 232, 223, 0.96));
}
.country-card__svg {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 70%;
  height: 70%;
  transform: translate(-50%, -50%);
}
.country-card__body {
  padding: 28rpx 28rpx 32rpx;
}
.country-card__icon {
  display: block;
  margin-bottom: 8rpx;
  font-size: 36rpx;
}
.country-card__name {
  display: block;
  color: var(--color-coffee-dark, #3e2a1e);
  font-size: 30rpx;
  font-weight: 600;
}
.country-card__flavors {
  display: block;
  margin-top: 8rpx;
  color: rgba(139, 115, 85, 0.86);
  font-size: 22rpx;
  line-height: 1.5;
}
.country-card-active {
  transform: scale(0.97);
  box-shadow: var(--shadow-card-hover, 0 36rpx 80rpx rgba(62, 42, 30, 0.1));
}

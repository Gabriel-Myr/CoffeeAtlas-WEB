.index-page{min-height:100vh;padding-bottom:80rpx}.index-page__header{align-items:center;display:flex;flex-direction:column;padding:96rpx 48rpx 56rpx;text-align:center}.index-page__title-en{color:var(--color-coffee-dark,#3e2a1e);font-size:56rpx;font-weight:700;letter-spacing:.05em;line-height:1}.index-page__title-atlas{color:var(--color-coffee-light,#8b7355);font-family:var(--font-serif,Georgia,serif);font-size:64rpx;font-style:italic;font-weight:500;line-height:1;margin-top:-8rpx}.index-page__subtitle{color:rgba(139,115,85,.84);font-size:20rpx;font-weight:600;letter-spacing:.32em;margin-top:28rpx;text-transform:uppercase}.index-page__tabs{border-bottom:2rpx solid var(--color-border,rgba(107,83,68,.12));display:flex;justify-content:center;margin:0 48rpx 56rpx}.index-page__tab{padding:0 48rpx 28rpx;position:relative}.index-page__tab--active::after{animation:fade-in .2s ease forwards;background:var(--color-coffee-dark,#3e2a1e);border-radius:var(--radius-pill,1998rpx);bottom:0;content:"";height:4rpx;left:0;position:absolute;right:0}.index-page__tab-text{color:rgba(139,115,85,.72);font-size:24rpx;font-weight:600;letter-spacing:.18em;text-transform:uppercase;transition:color .2s var(--smooth-easing,cubic-bezier(.4,0,.2,1))}.index-page__tab--active .index-page__tab-text{color:var(--color-coffee-dark,#3e2a1e)}.index-page__content{padding:0 var(--page-gutter)}.index-page__list{padding-top:16rpx}.index-page__notice{background:hsla(0,0%,100%,.9);border:2rpx solid rgba(107,83,68,.08);border-radius:40rpx;box-shadow:0 24rpx 48rpx rgba(62,42,30,.04);margin-bottom:36rpx;padding:28rpx 32rpx}.index-page__notice-label{color:var(--color-accent-rust,#c85c3d);display:block;font-size:22rpx;font-weight:700;letter-spacing:.18em;margin-bottom:12rpx;text-transform:uppercase}.index-page__notice-text{color:rgba(107,83,68,.88);display:block;font-size:26rpx;line-height:1.6}.discover__nav{align-items:center;animation:slide-in-left .3s ease forwards;border-bottom:2rpx solid rgba(107,83,68,.1);display:flex;gap:24rpx;margin-bottom:36rpx;padding:24rpx 8rpx 36rpx}.discover__nav-back{align-items:center;background:hsla(0,0%,100%,.96);border:2rpx solid rgba(107,83,68,.15);border-radius:50%;box-shadow:0 20rpx 48rpx rgba(62,42,30,.05);color:var(--color-coffee-dark,#3e2a1e);display:flex;flex-shrink:0;font-size:32rpx;height:72rpx;justify-content:center;width:72rpx}.discover__nav-info{min-width:0}.discover__nav-title{color:var(--color-coffee-dark,#3e2a1e);display:block;font-size:34rpx;font-weight:600}.discover__nav-sub{color:rgba(139,115,85,.8);display:block;font-size:20rpx;font-weight:600;letter-spacing:.2em;margin-top:8rpx;text-transform:uppercase}.discover__continents{display:flex;flex-direction:column;gap:28rpx}.discover__countries{display:grid;gap:24rpx;grid-template-columns:1fr 1fr}.discover__beans{padding-top:12rpx}.continent-card{align-items:stretch;animation:fade-in-up .45s ease forwards;background:hsla(0,0%,100%,.96);border:2rpx solid rgba(107,83,68,.08);border-radius:48rpx;box-shadow:var(--shadow-card,0 24rpx 60rpx rgba(62,42,30,.06));display:flex;min-height:176rpx;opacity:0;overflow:hidden;transition:transform .2s ease,box-shadow .2s ease}.continent-card__map{align-items:center;background:linear-gradient(180deg,hsla(37,39%,94%,.96),hsla(32,36%,91%,.96));border-right:2rpx solid rgba(107,83,68,.06);display:flex;flex-shrink:0;height:176rpx;justify-content:center;padding:28rpx;width:176rpx}.continent-card__svg{height:116rpx;width:116rpx}.continent-card__body{display:flex;flex:1;flex-direction:column;justify-content:center;min-width:0;padding:36rpx 32rpx}.continent-card__name{color:var(--color-coffee-dark,#3e2a1e);display:block;font-size:36rpx;font-weight:600}.continent-card__meta{align-items:center;display:flex;gap:12rpx;margin-top:12rpx}.continent-card__dot{border-radius:50%;flex-shrink:0;height:12rpx;width:12rpx}.continent-card__count{color:rgba(139,115,85,.86);font-size:24rpx;font-weight:600;letter-spacing:.08em}.continent-card__arrow{align-self:center;color:var(--color-coffee-pale,#d4c4b5);flex-shrink:0;font-size:48rpx;padding-right:32rpx}.continent-card-active{box-shadow:var(--shadow-card-hover,0 36rpx 80rpx rgba(62,42,30,.1));transform:scale(.98)}.country-card{animation:slide-in-bounce-left .5s var(--spring-easing,cubic-bezier(.175,.885,.32,1.275)) forwards;background:hsla(0,0%,100%,.96);border:2rpx solid rgba(107,83,68,.08);border-radius:40rpx;box-shadow:var(--shadow-card,0 24rpx 60rpx rgba(62,42,30,.06));opacity:0;overflow:hidden;transition:transform .2s ease,box-shadow .2s ease}.country-card__map{background:linear-gradient(180deg,hsla(37,39%,94%,.96),hsla(32,36%,91%,.96));padding-top:70%;position:relative;width:100%}.country-card__svg{height:70%;left:50%;position:absolute;top:50%;transform:translate(-50%,-50%);width:70%}.country-card__body{padding:28rpx 28rpx 32rpx}.country-card__icon{display:block;font-size:36rpx;margin-bottom:8rpx}.country-card__name{color:var(--color-coffee-dark,#3e2a1e);display:block;font-size:30rpx;font-weight:600}.country-card__flavors{color:rgba(139,115,85,.86);display:block;font-size:22rpx;line-height:1.5;margin-top:8rpx}.country-card-active{box-shadow:var(--shadow-card-hover,0 36rpx 80rpx rgba(62,42,30,.1));transform:scale(.97)}
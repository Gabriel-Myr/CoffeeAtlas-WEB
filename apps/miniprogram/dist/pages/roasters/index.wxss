.roaster-card{align-items:center;background:hsla(0,0%,100%,.96);border:2rpx solid rgba(107,83,68,.08);border-radius:48rpx;box-shadow:var(--shadow-card,0 24rpx 60rpx rgba(62,42,30,.06));display:flex;gap:32rpx;margin-bottom:32rpx;padding:36rpx;transition:transform .2s ease,box-shadow .2s ease}.roaster-card__avatar{align-items:center;background:linear-gradient(180deg,hsla(37,39%,94%,.98),hsla(31,43%,84%,.92));border-radius:36rpx;display:flex;flex-shrink:0;height:112rpx;justify-content:center;width:112rpx}.roaster-card__initial{color:var(--color-coffee-dark,#3e2a1e);font-size:48rpx;font-weight:700}.roaster-card__body{flex:1;min-width:0}.roaster-card__name{color:var(--color-coffee-dark,#3e2a1e);display:block;font-size:36rpx;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.roaster-card__city{color:rgba(139,115,85,.92);display:block;font-size:28rpx;margin-top:12rpx}.roaster-card__count{align-items:baseline;background:hsla(37,39%,94%,.98);border-radius:var(--radius-pill,1998rpx);display:flex;flex-shrink:0;gap:6rpx;padding:16rpx 20rpx}.roaster-card__count-num{color:var(--color-accent-rust,#c85c3d);font-size:32rpx;font-weight:700}.roaster-card__count-label{color:rgba(139,115,85,.92);font-size:24rpx;font-weight:600}.roaster-card__arrow{color:var(--color-coffee-pale,#d4c4b5);flex-shrink:0;font-size:44rpx}.roaster-card-active{box-shadow:var(--shadow-card-hover,0 36rpx 80rpx rgba(62,42,30,.1));transform:scale(.98)}.roasters-page{min-height:100vh;padding-bottom:80rpx}.roasters-page__header{align-items:center;display:flex;flex-direction:column;padding:96rpx 48rpx 56rpx;text-align:center}.roasters-page__header::before{color:rgba(139,115,85,.82);content:"COFFEE ATLAS";font-size:20rpx;font-weight:600;letter-spacing:.34em;text-transform:uppercase}.roasters-page__title{color:var(--color-coffee-dark,#3e2a1e);display:block;font-size:56rpx;font-weight:700;letter-spacing:.04em;margin-top:28rpx}.roasters-page__subtitle{color:rgba(139,115,85,.86);display:block;font-size:28rpx;margin-top:16rpx}.roasters-page__list{padding:16rpx 32rpx 0}.roasters-page__end,.roasters-page__loading{padding:56rpx 0 16rpx;text-align:center}.roasters-page__end-text,.roasters-page__loading-text{color:rgba(139,115,85,.72);font-size:26rpx}
.roasters-page {
  min-height: 100vh;
  background: radial-gradient(circle at top, rgba(245, 240, 232, 0.96), rgba(253, 250, 244, 0.98) 44%), linear-gradient(180deg, #f7f1e8 0%, #fdfaf4 42%, #fffdf8 100%);
  padding: 48rpx 0 80rpx;
}
.roasters-page__hero {
  padding: 88rpx 64rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}
.roasters-page__title-en {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-coffee-dark, #3E2A1E);
  letter-spacing: 0.08em;
  line-height: 1;
}
.roasters-page__title-atlas {
  margin-top: -8rpx;
  font-size: 40rpx;
  font-style: italic;
  font-weight: 500;
  color: var(--color-accent-rust, #c85c3d);
  line-height: 1;
}
.roasters-page__subtitle {
  margin-top: 36rpx;
  font-size: 24rpx;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--color-coffee-light, #8B7355);
}
.roasters-page__count {
  margin-top: 24rpx;
  font-size: 30rpx;
  color: var(--color-coffee-light, #8B7355);
}
.roasters-page__city-bar {
  margin: -24rpx 64rpx 32rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.roasters-page__city-chip {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(107, 83, 68, 0.1);
  font-size: 22rpx;
  color: var(--color-coffee-light, #8B7355);
}
.roasters-page__city-chip--active {
  background: var(--color-coffee-dark, #3E2A1E);
  border-color: var(--color-coffee-dark, #3E2A1E);
  color: #fff;
}
.roasters-page__query-bar {
  margin: 0 64rpx 36rpx;
  padding: 0 8rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 32rpx;
}
.roasters-page__query-text {
  font-size: 26rpx;
  color: var(--color-coffee-light, #8B7355);
}
.roasters-page__query-clear {
  font-size: 26rpx;
  color: var(--color-accent-rust, #c85c3d);
}
.roasters-page__list {
  padding: 0 64rpx;
}
.roasters-page__loading, .roasters-page__end {
  text-align: center;
  padding: 56rpx 0 16rpx;
}
.roasters-page__loading-text, .roasters-page__end-text {
  font-size: 26rpx;
  color: var(--color-coffee-pale, #d4c4b5);
}

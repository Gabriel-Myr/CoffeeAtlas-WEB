.roasters-page{min-height:100vh;padding-bottom:80rpx}.roasters-page__header{align-items:center;display:flex;flex-direction:column;padding:96rpx 48rpx 52rpx;position:relative;text-align:center}.roasters-page__header::after{background:linear-gradient(90deg,transparent,rgba(107,83,68,.26),transparent);content:"";height:2rpx;margin-top:36rpx;width:176rpx}.roasters-page__title-en{color:var(--color-coffee-dark,#3e2a1e);font-size:56rpx;font-weight:700;letter-spacing:.08em;line-height:1}.roasters-page__title-atlas{color:var(--color-coffee-light,#8b7355);font-family:var(--font-serif,Georgia,serif);font-size:68rpx;font-style:italic;font-weight:500;line-height:1;margin-top:-8rpx}.roasters-page__subtitle{color:rgba(139,115,85,.84);font-size:20rpx;font-weight:600;letter-spacing:.32em;margin-top:28rpx;text-transform:uppercase}.roasters-page__content{display:flex;flex-direction:column;gap:32rpx;padding:0 var(--page-gutter)}.roaster-atlas{display:flex;flex-direction:column;gap:32rpx;padding-bottom:16rpx}.roaster-atlas__toolbar{background:var(--atlas-paper,rgba(255,252,247,.96));border:2rpx solid var(--atlas-line,rgba(107,83,68,.12));border-radius:48rpx;box-shadow:var(--shadow-card,0 24rpx 60rpx rgba(62,42,30,.06));flex:1;min-width:0;overflow:hidden;padding:36rpx;position:relative}.roaster-atlas__toolbar::before{background:radial-gradient(circle,rgba(200,92,61,.12) 0,transparent 72%);content:"";height:240rpx;position:absolute;right:-20rpx;top:-48rpx;width:240rpx}.roaster-atlas__toolbar-kicker{color:var(--atlas-ink-soft,rgba(88,68,53,.72));display:block;font-size:20rpx;font-weight:700;letter-spacing:.24em;text-transform:uppercase}.roaster-atlas__toolbar-title{color:var(--color-coffee-dark,#3e2a1e);display:block;font-family:var(--font-serif,Georgia,serif);font-size:56rpx;font-weight:700;line-height:1.08;margin-top:12rpx}.roaster-atlas__toolbar-subtitle{color:var(--atlas-ink-soft,rgba(88,68,53,.72));display:block;font-size:26rpx;line-height:1.7;margin-top:20rpx}.roaster-atlas__filter-shell{margin-top:32rpx}.roaster-atlas__feature-scroll{margin:0 -36rpx;padding:0 36rpx;white-space:nowrap}.roaster-atlas__feature-row{display:inline-flex;gap:20rpx;padding-right:36rpx}.roaster-atlas__feature-chip{align-items:center;background:hsla(0,0%,100%,.7);border:2rpx solid var(--atlas-line,rgba(107,83,68,.08));border-radius:var(--radius-pill,1998rpx);display:inline-flex;justify-content:center;padding:16rpx 28rpx;transition:all .2s ease}.roaster-atlas__feature-chip--active{background:var(--color-coffee-dark,#3e2a1e);border-color:var(--color-coffee-dark,#3e2a1e)}.roaster-atlas__feature-chip--active .roaster-atlas__feature-text{color:#fff}.roaster-atlas__feature-text{color:var(--atlas-ink-soft,rgba(88,68,53,.72));font-size:22rpx;font-weight:700}.roaster-atlas__query-bar{align-items:center;background:linear-gradient(180deg,hsla(0,0%,100%,.78),hsla(33,48%,95%,.86)),hsla(0,0%,100%,.82);border:2rpx solid rgba(107,83,68,.08);border-radius:36rpx;box-shadow:inset 0 2rpx 0 hsla(0,0%,100%,.76);display:flex;gap:24rpx;justify-content:space-between;margin-top:32rpx;padding:24rpx 28rpx}.roaster-atlas__query-text{color:var(--atlas-ink-soft,rgba(88,68,53,.72));flex:1;font-size:24rpx;font-weight:600;line-height:1.5;min-width:0}.roaster-atlas__query-clear{align-items:center;background:rgba(200,92,61,.12);border-radius:1998rpx;color:var(--color-accent-rust,#c85c3d);display:inline-flex;flex-shrink:0;font-size:22rpx;font-weight:700;justify-content:center;letter-spacing:.08em;padding:12rpx 24rpx;text-transform:uppercase}.roaster-atlas__list{display:flex;flex-direction:column;gap:36rpx}.roaster-atlas__end,.roaster-atlas__loading{padding:48rpx 0 16rpx;text-align:center}.roaster-atlas__end-text,.roaster-atlas__loading-text{color:var(--atlas-ink-soft,rgba(88,68,53,.4));font-size:24rpx;letter-spacing:.1em;text-transform:uppercase}
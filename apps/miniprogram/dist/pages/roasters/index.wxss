.roasters-page{background:radial-gradient(circle at top,hsla(37,39%,94%,.96),hsla(40,69%,97%,.98) 44%),linear-gradient(180deg,#f7f1e8,#fdfaf4 42%,#fffdf8);min-height:100vh;padding:48rpx 0 80rpx}.roasters-page__hero{align-items:center;display:flex;flex-direction:column;padding:88rpx 64rpx 48rpx;text-align:center}.roasters-page__title-en{color:var(--color-coffee-dark,#3e2a1e);font-size:32rpx;font-weight:700;letter-spacing:.08em;line-height:1}.roasters-page__title-atlas{color:var(--color-accent-rust,#c85c3d);font-size:40rpx;font-style:italic;font-weight:500;line-height:1;margin-top:-8rpx}.roasters-page__subtitle{color:var(--color-coffee-light,#8b7355);font-size:24rpx;letter-spacing:.28em;margin-top:36rpx;text-transform:uppercase}.roasters-page__count{color:var(--color-coffee-light,#8b7355);font-size:30rpx;margin-top:24rpx}.roasters-page__city-bar{display:flex;flex-wrap:wrap;gap:12rpx;margin:-24rpx 64rpx 32rpx}.roasters-page__city-chip{background:hsla(0,0%,100%,.9);border:1rpx solid rgba(107,83,68,.1);border-radius:999rpx;color:var(--color-coffee-light,#8b7355);font-size:22rpx;padding:12rpx 22rpx}.roasters-page__city-chip--active{background:var(--color-coffee-dark,#3e2a1e);border-color:var(--color-coffee-dark,#3e2a1e);color:#fff}.roasters-page__query-bar{align-items:center;display:flex;gap:32rpx;justify-content:space-between;margin:0 64rpx 36rpx;padding:0 8rpx}.roasters-page__query-text{color:var(--color-coffee-light,#8b7355);font-size:26rpx}.roasters-page__query-clear{color:var(--color-accent-rust,#c85c3d);font-size:26rpx}.roasters-page__list{padding:0 64rpx}.roasters-page__end,.roasters-page__loading{padding:56rpx 0 16rpx;text-align:center}.roasters-page__end-text,.roasters-page__loading-text{color:var(--color-coffee-pale,#d4c4b5);font-size:26rpx}
.roaster-detail{background:radial-gradient(circle at top,hsla(37,39%,94%,.98),hsla(38,65%,97%,.94) 32%),linear-gradient(180deg,#f8f2e8,#fbf8f1 48%,#fffdf7);min-height:100vh;padding:48rpx 0 60rpx}.roaster-detail__hero{padding:0 24rpx}.roaster-detail__cover-shell{background:linear-gradient(145deg,rgba(91,67,52,.88),rgba(44,29,22,.96)),#4c3528;border-radius:38rpx;box-shadow:0 28rpx 52rpx rgba(62,42,30,.1);min-height:360rpx;overflow:hidden;position:relative}.roaster-detail__cover-fallback,.roaster-detail__cover-image{height:360rpx;width:100%}.roaster-detail__cover-image{background:hsla(0,0%,100%,.88);display:block}.roaster-detail__cover-fallback{align-items:center;background:radial-gradient(circle at top,hsla(32,37%,74%,.32),rgba(75,51,39,.92) 72%),#4c3528;display:flex;justify-content:center}.roaster-detail__cover-initial{color:rgba(255,247,237,.92);font-size:92rpx;font-weight:700;letter-spacing:.08em}.roaster-detail__cover-overlay{background:linear-gradient(180deg,rgba(35,24,19,.12),rgba(35,24,19,.64));display:flex;flex-direction:column;inset:0;justify-content:space-between;padding:26rpx;position:absolute}.roaster-detail__eyebrow{align-self:flex-start;backdrop-filter:blur(10rpx);background:rgba(255,248,240,.16);border:1rpx solid rgba(255,248,240,.2);border-radius:999rpx;color:rgba(255,249,244,.88);display:inline-flex;font-size:18rpx;letter-spacing:.24em;padding:10rpx 18rpx;text-transform:uppercase}.roaster-detail__cover-meta{display:flex;flex-wrap:wrap;gap:12rpx}.roaster-detail__meta-chip{background:rgba(255,249,244,.9);border-radius:999rpx;color:#6a4f3d;font-size:22rpx;padding:10rpx 18rpx}.roaster-detail__hero-card{background:linear-gradient(180deg,hsla(0,0%,100%,.98),hsla(35,67%,96%,.96)),#fff;border:1rpx solid rgba(107,83,68,.08);border-radius:32rpx;box-shadow:0 22rpx 40rpx rgba(62,42,30,.08),inset 0 1rpx 0 hsla(0,0%,100%,.88);margin-top:-42rpx;padding:28rpx 28rpx 30rpx;position:relative;z-index:1}.roaster-detail__hero-main{align-items:center;display:flex;gap:20rpx}.roaster-detail__logo,.roaster-detail__seal{background:hsla(37,52%,95%,.92);border:1rpx solid rgba(107,83,68,.08);border-radius:28rpx;flex-shrink:0;height:108rpx;width:108rpx}.roaster-detail__logo{display:block}.roaster-detail__seal{align-items:center;display:flex;justify-content:center}.roaster-detail__initial{color:#3e2a1e;font-size:42rpx;font-weight:700}.roaster-detail__title-wrap{flex:1;min-width:0}.roaster-detail__name{color:#332116;display:block;font-size:40rpx;font-weight:700;line-height:1.15}.roaster-detail__subtitle{color:rgba(139,115,85,.78);display:block;font-size:22rpx;letter-spacing:.16em;margin-top:10rpx;text-transform:uppercase}.roaster-detail__favorite{align-items:center;background:hsla(0,0%,100%,.96);border:1rpx solid rgba(107,83,68,.08);border-radius:50%;box-shadow:0 14rpx 24rpx rgba(62,42,30,.06);display:flex;flex-shrink:0;height:76rpx;justify-content:center;width:76rpx}.roaster-detail__intro{color:rgba(89,64,49,.92);display:block;font-size:26rpx;line-height:1.72;margin-top:22rpx}.roaster-detail__actions{display:grid;gap:14rpx;grid-template-columns:repeat(2,minmax(0,1fr));margin-top:24rpx}.roaster-detail__action-card{background:linear-gradient(180deg,hsla(36,48%,94%,.96),rgba(255,251,245,.96)),#fff;border:1rpx solid rgba(107,83,68,.08);border-radius:24rpx;display:flex;flex-direction:column;gap:10rpx;justify-content:space-between;min-height:112rpx;padding:18rpx 20rpx}.roaster-detail__action-label{color:#3e2a1e;font-size:28rpx;font-weight:600}.roaster-detail__action-note{color:rgba(139,115,85,.84);font-size:20rpx;line-height:1.45}.roaster-detail__social-chip{align-items:center;background:hsla(36,48%,94%,.88);border:1rpx solid rgba(107,83,68,.08);border-radius:999rpx;display:inline-flex;gap:10rpx;margin-top:18rpx;padding:14rpx 18rpx}.roaster-detail__social-prefix,.roaster-detail__social-text{color:rgba(107,83,68,.9);font-size:22rpx}.roaster-detail__section-head{align-items:baseline;display:flex;gap:20rpx;justify-content:space-between;padding:36rpx 32rpx 18rpx}.roaster-detail__section-title{color:#3e2a1e;font-size:32rpx;font-weight:600}.roaster-detail__section-sub{color:rgba(139,115,85,.74);font-size:20rpx;letter-spacing:.2em;text-transform:uppercase}.roaster-detail__beans{padding:0 32rpx}
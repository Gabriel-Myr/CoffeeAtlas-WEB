.roaster-detail{background:radial-gradient(circle at top,hsla(37,39%,94%,.96),hsla(40,69%,97%,.98) 40%),linear-gradient(180deg,#f7f1e8,#fdfaf4 42%,#fffdf8);min-height:100vh;padding:56rpx 0 60rpx}.roaster-detail__hero{background:linear-gradient(180deg,hsla(0,0%,100%,.98),hsla(40,69%,97%,.94)),#fff;border:1rpx solid rgba(107,83,68,.08);border-radius:32rpx;box-shadow:0 24rpx 48rpx rgba(62,42,30,.05),inset 0 1rpx 0 hsla(0,0%,100%,.86);margin:0 32rpx;padding:34rpx 30rpx}.roaster-detail__eyebrow{color:rgba(139,115,85,.72);display:block;font-size:20rpx;letter-spacing:.28em;text-transform:uppercase}.roaster-detail__hero-main{align-items:center;display:flex;gap:22rpx;margin-top:22rpx}.roaster-detail__logo,.roaster-detail__seal{border-radius:30rpx;flex-shrink:0;height:112rpx;width:112rpx}.roaster-detail__logo{background:#fff;border:1rpx solid rgba(107,83,68,.08)}.roaster-detail__seal{align-items:center;background:radial-gradient(circle at top,hsla(37,39%,94%,.98),hsla(0,0%,100%,.92) 72%),#fff;border:1rpx solid rgba(107,83,68,.08);display:flex;justify-content:center}.roaster-detail__initial{color:var(--color-coffee-dark,#3e2a1e);font-size:42rpx;font-weight:700;letter-spacing:.06em}.roaster-detail__title-wrap{flex:1;min-width:0}.roaster-detail__name{color:var(--color-coffee-dark,#3e2a1e);display:block;font-size:40rpx;font-weight:700;line-height:1.2}.roaster-detail__meta{display:flex;flex-wrap:wrap;gap:12rpx;margin-top:12rpx}.roaster-detail__city{color:var(--color-coffee-light,#8b7355);font-size:24rpx}.roaster-detail__meta-pill{background:hsla(37,39%,94%,.96);border:1rpx solid rgba(107,83,68,.08);border-radius:999rpx;color:var(--color-coffee-light,#8b7355);font-size:22rpx;padding:8rpx 14rpx}.roaster-detail__favorite{align-items:center;background:hsla(0,0%,100%,.92);border:1rpx solid rgba(107,83,68,.08);border-radius:50%;box-shadow:0 10rpx 22rpx rgba(62,42,30,.05);display:flex;flex-shrink:0;height:74rpx;justify-content:center;width:74rpx}.roaster-detail__intro{color:rgba(107,83,68,.88);display:block;font-size:26rpx;line-height:1.72;margin-top:24rpx}.roaster-detail__links{display:flex;flex-wrap:wrap;gap:14rpx;margin-top:26rpx}.roaster-detail__link-chip{align-items:center;background:hsla(37,39%,94%,.9);border:1rpx solid rgba(107,83,68,.08);border-radius:999rpx;display:inline-flex;gap:10rpx;padding:14rpx 18rpx}.roaster-detail__link-prefix,.roaster-detail__link-text{color:var(--color-coffee-light,#8b7355);font-size:23rpx}.roaster-detail__section-head{align-items:baseline;display:flex;gap:24rpx;justify-content:space-between;padding:34rpx 32rpx 18rpx}.roaster-detail__section-title{color:var(--color-coffee-dark,#3e2a1e);font-size:32rpx;font-weight:600}.roaster-detail__section-sub{color:rgba(139,115,85,.72);font-size:20rpx;letter-spacing:.2em;text-transform:uppercase}.roaster-detail__beans{padding:0 32rpx}
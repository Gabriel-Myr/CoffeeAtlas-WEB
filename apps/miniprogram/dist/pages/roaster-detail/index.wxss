.roaster-detail{min-height:100vh;padding:48rpx 0 80rpx}.roaster-detail__hero{align-items:center;background:hsla(0,0%,100%,.96);border:2rpx solid rgba(107,83,68,.08);border-radius:56rpx;box-shadow:var(--shadow-card,0 24rpx 60rpx rgba(62,42,30,.06));display:flex;flex-direction:column;margin:0 32rpx;padding:64rpx 48rpx 56rpx;text-align:center}.roaster-detail__logo{border-radius:40rpx;height:144rpx;margin-bottom:32rpx;width:144rpx}.roaster-detail__avatar{align-items:center;background:linear-gradient(180deg,hsla(37,39%,94%,.98),hsla(31,43%,84%,.92));border-radius:48rpx;display:flex;height:144rpx;justify-content:center;margin-bottom:32rpx;width:144rpx}.roaster-detail__initial{color:var(--color-coffee-dark,#3e2a1e);font-size:56rpx;font-weight:700}.roaster-detail__name{color:var(--color-coffee-dark,#3e2a1e);font-size:52rpx;font-weight:700;line-height:1.2}.roaster-detail__city{color:rgba(139,115,85,.86);font-size:28rpx;margin-top:12rpx}.roaster-detail__links,.roaster-detail__section{background:hsla(0,0%,100%,.94);border:2rpx solid rgba(107,83,68,.08);border-radius:48rpx;box-shadow:var(--shadow-card,0 24rpx 60rpx rgba(62,42,30,.06));margin:32rpx 32rpx 0;padding:40rpx}.roaster-detail__desc{color:rgba(62,42,30,.78);font-size:30rpx;line-height:1.8}.roaster-detail__links{display:flex;flex-direction:column;gap:20rpx}.roaster-detail__link{color:rgba(139,115,85,.92);font-size:28rpx;line-height:1.5}.roaster-detail__beans-header{align-items:center;display:flex;justify-content:space-between;padding:64rpx 32rpx 28rpx}.roaster-detail__beans-title{color:var(--color-coffee-dark,#3e2a1e);font-size:36rpx;font-weight:600;letter-spacing:.04em}.roaster-detail__beans-count{color:rgba(139,115,85,.88);font-size:26rpx}.roaster-detail__beans{padding:0 32rpx}
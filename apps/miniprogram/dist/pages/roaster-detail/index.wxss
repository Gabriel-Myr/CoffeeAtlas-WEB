.roaster-detail {
  min-height: 100vh;
  background: radial-gradient(circle at top, rgba(245, 240, 232, 0.96), rgba(253, 250, 244, 0.98) 40%), linear-gradient(180deg, #f7f1e8 0%, #fdfaf4 42%, #fffdf8 100%);
  padding: 56rpx 0 60rpx;
}
.roaster-detail__hero {
  margin: 0 32rpx;
  padding: 34rpx 30rpx;
  border-radius: 32rpx;
  border: 1rpx solid rgba(107, 83, 68, 0.08);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(253, 250, 244, 0.94)), #fff;
  box-shadow: 0 24rpx 48rpx rgba(62, 42, 30, 0.05), inset 0 1rpx 0 rgba(255, 255, 255, 0.86);
}
.roaster-detail__eyebrow {
  display: block;
  font-size: 20rpx;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: rgba(139, 115, 85, 0.72);
}
.roaster-detail__hero-main {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
  gap: 22rpx;
}
.roaster-detail__logo, .roaster-detail__seal {
  width: 112rpx;
  height: 112rpx;
  border-radius: 30rpx;
  flex-shrink: 0;
}
.roaster-detail__logo {
  border: 1rpx solid rgba(107, 83, 68, 0.08);
  background: #fff;
}
.roaster-detail__seal {
  display: flex;
  align-items: center;
  justify-content: center;
  background: radial-gradient(circle at top, rgba(245, 240, 232, 0.98), rgba(255, 255, 255, 0.92) 72%), #fff;
  border: 1rpx solid rgba(107, 83, 68, 0.08);
}
.roaster-detail__initial {
  font-size: 42rpx;
  font-weight: 700;
  color: var(--color-coffee-dark, #3E2A1E);
  letter-spacing: 0.06em;
}
.roaster-detail__title-wrap {
  flex: 1;
  min-width: 0;
}
.roaster-detail__name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-coffee-dark, #3E2A1E);
  line-height: 1.2;
}
.roaster-detail__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}
.roaster-detail__city {
  font-size: 24rpx;
  color: var(--color-coffee-light, #8B7355);
}
.roaster-detail__meta-pill {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(245, 240, 232, 0.96);
  border: 1rpx solid rgba(107, 83, 68, 0.08);
  font-size: 22rpx;
  color: var(--color-coffee-light, #8B7355);
}
.roaster-detail__favorite {
  width: 74rpx;
  height: 74rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(107, 83, 68, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 10rpx 22rpx rgba(62, 42, 30, 0.05);
}
.roaster-detail__intro {
  display: block;
  margin-top: 24rpx;
  font-size: 26rpx;
  line-height: 1.72;
  color: rgba(107, 83, 68, 0.88);
}
.roaster-detail__links {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 26rpx;
}
.roaster-detail__link-chip {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(245, 240, 232, 0.9);
  border: 1rpx solid rgba(107, 83, 68, 0.08);
}
.roaster-detail__link-prefix, .roaster-detail__link-text {
  font-size: 23rpx;
  color: var(--color-coffee-light, #8B7355);
}
.roaster-detail__section-head {
  padding: 34rpx 32rpx 18rpx;
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 24rpx;
}
.roaster-detail__section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-coffee-dark, #3E2A1E);
}
.roaster-detail__section-sub {
  font-size: 20rpx;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(139, 115, 85, 0.72);
}
.roaster-detail__beans {
  padding: 0 32rpx;
}

.roaster-card {
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 28rpx;
  margin-bottom: 18rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(107, 83, 68, 0.08);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(253, 250, 244, 0.92)), var(--color-card-bg, #fff);
  box-shadow: 0 18rpx 36rpx rgba(62, 42, 30, 0.04), inset 0 1rpx 0 rgba(255, 255, 255, 0.85);
  animation: fade-in-up 0.45s ease forwards;
  opacity: 0;
  transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
}
.roaster-card__media {
  width: 96rpx;
  height: 96rpx;
  flex-shrink: 0;
  border-radius: 28rpx;
  border: 1rpx solid rgba(107, 83, 68, 0.08);
  background: radial-gradient(circle at top, rgba(245, 240, 232, 0.95), rgba(255, 255, 255, 0.92) 70%), #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.roaster-card__logo {
  width: 100%;
  height: 100%;
}
.roaster-card__seal {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 1.5rpx solid rgba(62, 42, 30, 0.16);
  background: rgba(245, 240, 232, 0.78);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
}
.roaster-card__initial {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-coffee-dark, #3E2A1E);

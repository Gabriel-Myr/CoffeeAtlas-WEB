}
.roaster-card__body {
  flex: 1;
  min-width: 0;
}
.roaster-card__eyebrow {
  display: block;
  font-size: 18rpx;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: rgba(139, 115, 85, 0.72);
}
.roaster-card__name {
  display: block;
  margin-top: 8rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-coffee-dark, #3E2A1E);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

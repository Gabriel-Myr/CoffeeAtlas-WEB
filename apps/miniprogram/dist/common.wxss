.search-bar{align-items:center;background:hsla(0,0%,100%,.96);border:2rpx solid var(--color-border,rgba(107,83,68,.15));border-radius:var(--radius-pill,1998rpx);box-shadow:0 24rpx 48rpx rgba(62,42,30,.04);display:flex;height:112rpx;margin:0 var(--page-gutter) 48rpx;padding:0 36rpx}.search-bar__icon{flex-shrink:0;margin-right:24rpx}.search-bar__input{color:var(--color-coffee-dark,#3e2a1e);flex:1;font-size:32rpx;height:112rpx;line-height:112rpx}.search-bar__placeholder{color:rgba(139,115,85,.52);font-size:30rpx}.bean-card{animation:fade-in-up .45s ease forwards;background:hsla(0,0%,100%,.96);border:2rpx solid rgba(107,83,68,.08);border-radius:var(--radius-card-lg,56rpx);box-shadow:var(--shadow-card,0 24rpx 60rpx rgba(62,42,30,.06));display:flex;flex-direction:column;margin-bottom:40rpx;opacity:0;overflow:hidden;transition:transform .2s ease,box-shadow .2s ease,opacity .2s ease}.bean-card__image{background:linear-gradient(180deg,hsla(37,39%,94%,.98),hsla(33,36%,90%,.92));overflow:hidden;padding-top:100%;position:relative;width:100%}.bean-card__img{height:100%;left:0;position:absolute;top:0;width:100%}.bean-card__placeholder{align-items:center;display:flex;height:100%;justify-content:center;left:0;position:absolute;top:0;width:100%}.bean-card__badge{background:hsla(0,0%,100%,.92);border-radius:var(--radius-pill,1998rpx);box-shadow:0 16rpx 40rpx rgba(62,42,30,.08);color:var(--color-coffee-dark,#3e2a1e);font-size:22rpx;font-weight:700;left:24rpx;letter-spacing:.18em;padding:14rpx 24rpx;position:absolute;text-transform:uppercase;top:24rpx}.bean-card__body{display:flex;flex-direction:column;flex-grow:1;min-width:0;padding:32rpx 36rpx 36rpx}.bean-card__meta{align-items:flex-start;display:flex;gap:24rpx;justify-content:space-between}.bean-card__titles{flex:1;min-width:0}.bean-card__line1,.bean-card__line2{color:var(--color-coffee-dark,#3e2a1e);display:block;font-family:var(--font-serif,Georgia,serif);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.bean-card__line1{font-size:32rpx;font-weight:600;line-height:1.3}.bean-card__line2{color:rgba(62,42,30,.72);font-size:30rpx;line-height:1.35;margin-top:8rpx}.bean-card__tags{align-items:flex-end;display:flex;flex-direction:column;flex-shrink:0;gap:12rpx}.bean-card__tag{border-radius:var(--radius-pill,1998rpx);color:#fff;font-size:22rpx;font-weight:700;letter-spacing:.08em;padding:12rpx 20rpx}.bean-card__tag--sales{background:var(--color-accent-olive,#5a5a40)}.bean-card__tag--price{background:var(--color-accent-rust,#c85c3d)}.bean-card__footer{border-top:2rpx solid rgba(107,83,68,.1);display:flex;flex-direction:column;gap:8rpx;margin-top:32rpx;padding-top:24rpx}.bean-card__label{color:rgba(139,115,85,.88);font-size:22rpx;font-weight:600;letter-spacing:.18em;text-transform:uppercase}.bean-card__value{color:var(--color-coffee-dark,#3e2a1e);font-size:28rpx;font-weight:600}.bean-card-active{box-shadow:var(--shadow-card-hover,0 36rpx 80rpx rgba(62,42,30,.1));opacity:.94;transform:scale(.98)}.empty-state{align-items:center;display:flex;flex-direction:column;justify-content:center;padding:144rpx 64rpx}.empty-state__icon{margin-bottom:24rpx}.empty-state__text{color:rgba(139,115,85,.82);font-size:30rpx;letter-spacing:.04em;text-align:center}
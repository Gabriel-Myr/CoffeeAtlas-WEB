{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@coffee-atlas/shared-types": ["packages/shared-types/src/index.ts"],
      "@coffee-atlas/api-client": ["packages/api-client/src/index.ts"],
      "@coffee-atlas/domain": ["packages/domain/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", ".next"]
}
